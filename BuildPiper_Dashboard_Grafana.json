          "hideZeros": false,
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-http-buildpiper\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "BP Endpoint Health \u2014 UP/DOWN Timeline",
      "type": "state-timeline"
    },
    {
      "description": "Currently executing tasks per worker and prefetched tasks waiting at worker. Rising prefetched = queue backing up. Source: Flower /metrics",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
