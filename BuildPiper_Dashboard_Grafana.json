      ],
      "title": "BP Celery \u2014 Active & Prefetched Tasks per Worker",
      "type": "timeseries"
    },
    {
      "description": "Worker online=1 offline=0. Drop to 0 = worker crashed. Task completion rate shows throughput per worker.",
